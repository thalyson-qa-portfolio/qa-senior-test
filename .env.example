# Copie para .env na raiz do projeto: cp .env.example .env
# O carregamento é feito em e2e/support/config.ts (import 'dotenv/config') ao correr Playwright ou Cucumber.

# URLs — testes de API (Playwright) e E2E (Cucumber). Opcional: defaults = Restful-Booker + Automation Exercise.
# API_BASE_URL=https://restful-booker.herokuapp.com
# E2E_BASE_URL=https://automationexercise.com

# E2E (Cucumber + Playwright) — e2e/support/hooks.ts
# HEADLESS=false   # abre o navegador visivel (padrao: headless)
# SLOWMO=500       # atraso entre acoes em ms (opcional)
# VIDEO=true       # grava video em test-output/videos/

# K6 (performance/load-test.js) — o K6 NAO le .env sozinho; use export ou k6 run -e ...
# No GitHub Actions, o mesmo conjunto pode ser definido em Actions > Variables (ver docs/PERFORMANCE_TESTS.md).
# K6_BASE_URL=https://test.k6.io
# K6_RAMP_DURATION=1m
# K6_LOAD_DURATION=5m
# K6_RAMP_DOWN_DURATION=1m
# K6_TARGET_VUS=500
# K6_VUS=500
# K6_SLEEP_S=1
# K6_P95_MS=2000
# K6_HTTP_FAIL_RATE_MAX=0.1
# K6_ERRORS_RATE_MAX=0.1
