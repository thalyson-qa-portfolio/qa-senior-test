# URLs da API (Playwright), E2E e alvos de teste estao em e2e/support/config.ts
# (este arquivo nao sobrescreve essas URLs hoje).

# Variaveis abaixo sao lidas via process.env (export no shell, CI, etc.).
# O projeto nao carrega automaticamente um arquivo .env — use export ou dotenv no seu fluxo.

# E2E (Cucumber + Playwright) — e2e/support/hooks.ts
# HEADLESS=false   # abre o navegador visivel (padrao: headless)
# SLOWMO=500       # atraso entre acoes em ms (opcional)
# VIDEO=true       # grava video em test-output/videos/
