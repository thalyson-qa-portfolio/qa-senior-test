{
  "name": "qa-senior-test",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "test:api": "npx playwright test",
    "test:e2e": "node -e \"try{require('fs').rmSync('test-output/allure-results',{recursive:true,force:true})}catch(e){}\" && npx cucumber-js",
    "test": "npm run test:api && npm run test:e2e",
    "test:perf": "k6 run performance/load-test.js",
    "test:perf:smoke": "k6 run --vus 10 --duration 30s performance/load-test.js",
    "report:allure": "npx allure generate test-output/allure-results -o test-output/allure-report --clean",
    "report:allure:open": "npx allure open test-output/allure-report"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@cucumber/cucumber": "^11.3.0",
    "@cucumber/messages": "^32.2.0",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "allure-commandline": "^2.38.1",
    "allure-cucumberjs": "^3.6.0",
    "allure-js-commons": "^3.6.0",
    "dotenv": "^17.3.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  }
}
